{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Represents a user account and their role.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "staff", "admin"] },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role", "createdAt"]
    },
    "Order": {
      "title": "Customer Order",
      "description": "Represents an order created by a customer.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "customerPhone": { "type": "string" },
        "items": { "type": "array" },
        "totalPrice": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "customerId", "customerName", "customerEmail", "customerPhone", "items", "totalPrice", "status", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles indexed by their uid."
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders collection."
    }
  }
}
